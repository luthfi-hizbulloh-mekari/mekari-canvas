# Publisher sign-in (Better Auth). Omit Google creds locally to use dev bypass below.
BETTER_AUTH_SECRET=local-dev-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local dev bypass — never set on Vercel
DEV_AUTH_BYPASS=true
DEV_PUBLISHER_EMAIL=you@mekari.com

# Production storage (auto-provisioned via Vercel Marketplace). Omit locally to use .data/
# Blob: either BLOB_READ_WRITE_TOKEN, or link the store (sets BLOB_STORE_ID + OIDC on Vercel)
BLOB_READ_WRITE_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Set only if the Blob store was created as Private (default: public)
# BLOB_STORE_ACCESS=private
